:root {
  --orange: #ff8f1f;
  --orange-dark: #f26f13;
  --yellow: #ffd21f;
  --cream: #fffbe9;
  --red: #d7261d;
  --ink: #17120d;
  --muted: #6c6258;
  --line: #e5d8be;
  --white: #ffffff;
  --green: #2c9c52;
  --shadow: 0 14px 34px rgba(70, 45, 16, 0.14);
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  min-width: 320px;
  color: var(--ink);
  background: #efefef;
}

.restaurant-app {
  min-height: 100vh;
  font-family: Arial, Helvetica, sans-serif;
  color: var(--ink);
}

button,
input {
  font: inherit;
}

button {
  cursor: pointer;
}

.site-header {
  position: sticky;
  top: 0;
  z-index: 20;
  min-height: 58px;
  padding: 10px clamp(16px, 4vw, 56px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
  background: var(--orange);
  box-shadow: 0 4px 16px rgba(80, 42, 5, 0.15);
}

.brand {
  border: 0;
  background: transparent;
  color: var(--ink);
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  font-weight: 900;
  letter-spacing: 0;
}

.brand-logo {
  width: 48px;
  height: 48px;
  display: block;
  object-fit: contain;
  border-radius: 50%;
  background: #ffffff;
}

.brand-logo.big {
  width: 92px;
  height: 92px;
  margin: 0 auto 12px;
}

.main-nav {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8px;
}

.main-nav button {
  min-width: 72px;
  padding: 8px 12px;
  border: 0;
  border-radius: 4px;
  background: var(--yellow);
  color: var(--ink);
  font-size: 12px;
  font-weight: 800;
  text-align: center;
}

.main-nav button.active,
.main-nav button:hover {
  background: var(--ink);
  color: var(--white);
}

.view.active {
  display: block;
}

.page-shell {
  width: min(1120px, calc(100% - 32px));
  margin: 0 auto;
  padding: 38px 0 58px;
}

.home-layout,
.reservation-layout,
.admin-shell {
  min-height: calc(100vh - 58px);
  background: var(--cream);
}

.home-layout {
  padding-inline: clamp(12px, 3vw, 28px);
}

.hero-panel {
  min-height: 360px;
  padding: clamp(22px, 5vw, 48px);
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(300px, 520px);
  align-items: center;
  gap: clamp(24px, 5vw, 56px);
  background:
    linear-gradient(120deg, rgba(255, 255, 255, 0.88), rgba(255, 239, 194, 0.58)),
    radial-gradient(circle at 78% 18%, rgba(255, 143, 31, 0.24), transparent 34%);
  border-bottom: 1px solid var(--line);
}

.eyebrow {
  margin: 0 0 8px;
  color: var(--red);
  font-size: 13px;
  font-weight: 900;
  text-transform: uppercase;
}

h1,
h2,
h3,
p {
  margin-top: 0;
}

h1 {
  margin-bottom: 14px;
  font-size: clamp(30px, 5vw, 54px);
  line-height: 1;
  font-weight: 900;
}

h2 {
  margin-bottom: 14px;
  font-size: clamp(22px, 3vw, 34px);
  font-weight: 900;
}

.hero-copy p:not(.eyebrow),
.reservation-copy p,
.section-heading span {
  color: var(--muted);
  line-height: 1.6;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 24px;
}

.primary-action,
.secondary-action,
.mini-action {
  border: 0;
  border-radius: 5px;
  font-weight: 900;
  text-transform: uppercase;
}

.primary-action {
  padding: 13px 24px;
  color: var(--white);
  background: var(--orange-dark);
}

.secondary-action {
  padding: 13px 24px;
  color: var(--ink);
  background: var(--yellow);
}

.mini-action {
  padding: 7px 12px;
  color: var(--white);
  background: var(--orange-dark);
  font-size: 11px;
}

.delivery-scene {
  position: relative;
  min-height: 310px;
  display: grid;
  place-items: center;
  overflow: hidden;
  border: 2px solid #98d5df;
  background: #dcfbff;
}

.delivery-image {
  width: 100%;
  height: 100%;
  min-height: 310px;
  display: block;
  object-fit: cover;
}

.phone-mock {
  position: relative;
  z-index: 2;
  width: 148px;
  min-height: 238px;
  padding: 24px 16px;
  display: grid;
  justify-items: center;
  align-content: center;
  gap: 8px;
  border: 8px solid #202020;
  border-radius: 24px;
  background: #fff7e7;
  box-shadow: var(--shadow);
  text-align: center;
}

.phone-camera {
  position: absolute;
  top: 8px;
  width: 34px;
  height: 5px;
  border-radius: 999px;
  background: #1e1e1e;
}

.phone-food {
  width: 78px;
  height: 78px;
  display: grid;
  place-items: center;
  border-radius: 50%;
  background: #ffe2a5;
  font-size: 45px;
}

.food-bubble {
  position: absolute;
  width: 72px;
  height: 72px;
  display: grid;
  place-items: center;
  border-radius: 50%;
  background: #ffffff;
  font-size: 34px;
  box-shadow: var(--shadow);
}

.bubble-one {
  top: 44px;
  left: 45px;
}

.bubble-two {
  right: 42px;
  top: 66px;
}

.bubble-three {
  left: 82px;
  bottom: 46px;
}

.delivery-rider {
  position: absolute;
  right: 82px;
  bottom: 28px;
  font-size: 72px;
}

.section-block {
  padding: 34px 0;
}

.section-heading {
  max-width: 760px;
}

.page-title {
  margin-bottom: 28px;
}

.promo-grid,
.testimonial-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18px;
}

.promo-card,
.testimonial-grid article,
.menu-card,
.location-card,
.admin-card,
.admin-panel,
.reservation-form,
.table-wrap,
.metric-grid article {
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--white);
  box-shadow: var(--shadow);
}

.promo-card {
  min-height: 190px;
  padding: 22px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.promo-card span {
  font-size: 48px;
  font-weight: 900;
  line-height: 1;
}

.promo-card h3 {
  margin: 10px 0 6px;
  font-size: 22px;
  font-weight: 900;
}

.promo-card p {
  color: rgba(255, 255, 255, 0.86);
}

.promo-red,
.promo-dark {
  color: var(--white);
}

.promo-red {
  background: linear-gradient(135deg, #d7261d, #7b0e0a);
}

.promo-yellow {
  color: var(--ink);
  background: linear-gradient(135deg, #ffd21f, #ff8f1f);
}

.promo-yellow p {
  color: #3f2b12;
}

.promo-dark {
  background: linear-gradient(135deg, #1c1712, #5a2416);
}

.app-band {
  padding: 26px;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(240px, 430px);
  align-items: center;
  gap: 28px;
  border: 2px solid #f58324;
  background: #fff0e5;
}

.app-band li {
  margin: 12px 0;
  line-height: 1.5;
}

.app-preview {
  min-height: 210px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  background: linear-gradient(120deg, #fff, #ffe4c4);
}

.mini-phone {
  width: 92px;
  height: 172px;
  border: 8px solid #1f1f1f;
  border-radius: 22px;
  background:
    radial-gradient(circle at 50% 40%, #ff8f1f 0 22%, transparent 23%),
    linear-gradient(#fffaf0 0 28%, #ffd0a2 29% 100%);
}

.mini-phone.second {
  transform: translateY(18px);
}

.qr-box {
  width: 62px;
  height: 62px;
  display: grid;
  place-items: center;
  color: #fff;
  background: #111;
  font-weight: 900;
}

.testimonial-grid article {
  padding: 20px;
}

.testimonial-grid p {
  margin-bottom: 0;
  color: var(--muted);
}

.menu-stack {
  display: grid;
  gap: 34px;
}

.menu-category h2 {
  display: flex;
  align-items: center;
  gap: 10px;
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 22px;
}

.menu-card {
  overflow: hidden;
}

.food-art {
  min-height: 154px;
  width: 100%;
  height: 180px;
  display: block;
  object-fit: cover;
  background: #f7d59b;
}

.menu-card:nth-child(2n) .food-art {
  background: #e7f1d0;
}

.menu-card:nth-child(3n) .food-art {
  background: #ffd6c2;
}

.menu-info {
  padding: 16px;
}

.menu-info h3 {
  margin-bottom: 5px;
  font-weight: 900;
}

.menu-info p {
  min-height: 54px;
  color: var(--muted);
  line-height: 1.45;
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.price-row strong {
  color: var(--red);
}

.locations-list {
  display: grid;
  gap: 22px;
}

.location-card {
  padding: 18px;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 250px;
  align-items: center;
  gap: 24px;
}

.location-info h2 {
  color: var(--red);
  font-size: 22px;
}

.location-info p {
  color: var(--muted);
}

.map-preview {
  min-height: 138px;
  border-radius: 8px;
  border: 1px solid #cfd9ca;
  background:
    linear-gradient(90deg, transparent 47%, rgba(72, 146, 255, 0.45) 48% 52%, transparent 53%),
    linear-gradient(15deg, transparent 48%, rgba(111, 184, 96, 0.4) 49% 53%, transparent 54%),
    linear-gradient(105deg, transparent 42%, rgba(226, 109, 93, 0.32) 43% 46%, transparent 47%),
    #edf1eb;
  position: relative;
}

.map-preview::after {
  content: "";
  position: absolute;
  right: 34%;
  top: 42%;
  width: 18px;
  height: 18px;
  border: 5px solid #2c78ff;
  border-radius: 50% 50% 50% 0;
  background: #fff;
  transform: rotate(-45deg);
}

.reservation-layout {
  padding-inline: clamp(16px, 4vw, 46px);
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(320px, 520px);
  align-items: center;
  gap: clamp(28px, 7vw, 80px);
}

.reservation-form {
  padding: 32px;
}

.reservation-form h2 {
  text-align: center;
}

.reservation-form label,
.login-card label {
  display: grid;
  gap: 7px;
  margin-bottom: 16px;
  font-size: 13px;
  font-weight: 800;
}

.reservation-form input,
.login-card input {
  width: 100%;
  min-height: 40px;
  border: 1px solid #cfc5b2;
  padding: 10px 12px;
  background: #f7f7f7;
}

.two-columns {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.form-message {
  min-height: 22px;
  margin: 14px 0 0;
  color: var(--green);
  font-weight: 800;
  text-align: center;
}

.reservation-icon {
  margin-top: 40px;
  font-size: 54px;
}

.admin-shell {
  width: min(1040px, calc(100% - 32px));
  padding-inline: 0;
}

.login-panel {
  min-height: 600px;
  display: grid;
  place-items: center;
}

.login-card {
  width: min(420px, 100%);
  padding: 30px;
  text-align: center;
  border: 3px solid #2196f3;
}

.login-card p {
  color: var(--muted);
}

.admin-dashboard {
  display: grid;
  grid-template-columns: 260px minmax(0, 1fr);
  gap: 28px;
}

.admin-menu {
  padding: 24px;
  background: rgba(255, 255, 255, 0.42);
}

.admin-menu h1 {
  color: var(--orange-dark);
  font-size: 28px;
  text-align: center;
}

.admin-menu button {
  width: 100%;
  min-height: 62px;
  margin: 12px 0;
  border: 0;
  border-radius: 5px;
  color: #fff;
  background: var(--orange-dark);
  font-weight: 900;
  text-transform: uppercase;
}

.admin-panel {
  padding: 24px;
}

.admin-title h2 {
  display: inline-block;
  padding: 10px 46px;
  border-radius: 7px;
  color: #fff;
  background: var(--orange-dark);
}

.table-wrap {
  overflow-x: auto;
}

table {
  width: 100%;
  border-collapse: collapse;
}

th,
td {
  padding: 13px;
  border-bottom: 1px solid var(--line);
  text-align: left;
}

th {
  font-size: 13px;
  text-transform: uppercase;
}

.table-actions {
  display: flex;
  gap: 6px;
}

.table-actions button,
.admin-grid button {
  border: 0;
  border-radius: 4px;
  padding: 7px 9px;
  color: #fff;
  background: var(--orange-dark);
  font-size: 11px;
  font-weight: 800;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
  margin-bottom: 18px;
}

.metric-grid article {
  padding: 14px;
  text-align: center;
}

.metric-grid span {
  display: block;
  color: var(--red);
  font-size: 34px;
  font-weight: 900;
}

.metric-grid small {
  color: var(--muted);
  font-weight: 800;
  text-transform: uppercase;
}

.admin-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.mini-admin-card {
  padding: 14px;
  border: 1px solid var(--line);
  border-radius: 7px;
  background: #fff8e8;
}

.mini-admin-card h3 {
  margin-bottom: 8px;
  font-size: 16px;
  font-weight: 900;
}

.mini-admin-card p {
  margin-bottom: 6px;
  color: var(--muted);
  font-size: 13px;
}

.site-footer {
  min-height: 92px;
  padding: 22px clamp(16px, 4vw, 56px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  background: #fff;
  color: var(--muted);
  font-size: 13px;
}

.site-footer div {
  display: grid;
  gap: 5px;
}

.site-footer strong {
  color: var(--ink);
}

@media (max-width: 860px) {
  .site-header {
    position: static;
    align-items: flex-start;
    flex-direction: column;
  }

  .main-nav {
    justify-content: flex-start;
  }

  .hero-panel,
  .reservation-layout,
  .admin-dashboard,
  .location-card,
  .app-band {
    grid-template-columns: 1fr;
  }

  .menu-grid,
  .promo-grid,
  .testimonial-grid,
  .admin-grid {
    grid-template-columns: 1fr;
  }

  .delivery-scene {
    min-height: 260px;
  }

  .location-card {
    align-items: stretch;
  }
}

@media (max-width: 560px) {
  .page-shell {
    width: min(100% - 20px, 1120px);
    padding-top: 24px;
  }

  .main-nav button {
    min-width: 0;
    flex: 1 1 96px;
  }

  .hero-panel {
    padding: 20px;
  }

  .food-bubble {
    width: 58px;
    height: 58px;
    font-size: 28px;
  }

  .delivery-rider {
    right: 28px;
    font-size: 54px;
  }

  .two-columns,
  .metric-grid {
    grid-template-columns: 1fr;
  }

  .reservation-form {
    padding: 22px;
  }

  .site-footer {
    align-items: flex-start;
    flex-direction: column;
  }
}




.admin-grid button.danger-action {
  background: var(--red);
}

.empty-state {
  padding: 18px;
  border: 1px solid var(--line);
  border-radius: 8px;
  color: var(--muted);
  background: var(--white);
  box-shadow: var(--shadow);
}
